# Local Postgres (docker compose up -d)
DATABASE_URL="postgresql://moka:moka@localhost:5432/moka?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"

# Set false in production (default). Demo checkout only when true or in development.
ALLOW_DEMO_PAYMENTS="false"

ADMIN_EMAIL="admin@mokaindia.com"
ADMIN_PASSWORD="change-this-strong-password"
