# Local Postgres (docker compose up -d)
DATABASE_URL="postgresql://moka:moka@localhost:5432/moka?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"

# Set false in production (default). Demo checkout only when true or in development.
ALLOW_DEMO_PAYMENTS="false"

ADMIN_EMAIL="admin@mokaindia.com"
ADMIN_PASSWORD="change-this-strong-password"

# Image uploads (optional)
# On production without Cloudinary, uploads are stored inline in the DB (persists on Render).
# Locally, files go to public/uploads unless UPLOAD_MODE=inline.
# UPLOAD_MODE=inline|disk
#
# Optional Cloudinary (recommended for many/large images):
# CLOUDINARY_CLOUD_NAME=your_cloud
# CLOUDINARY_UPLOAD_PRESET=moka_unsigned
